# Public Firebase browser configuration
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server-side Australian address search. Google Geocoding is supported directly;
# another approved provider can return the documented suggestions contract.
TLINK_ADDRESS_AUTOCOMPLETE_ENDPOINT=https://maps.googleapis.com/maps/api/geocode/json
TLINK_ADDRESS_AUTOCOMPLETE_TOKEN=

# TLink Stripe membership configuration. URLs and payment-link IDs are commercial
# settings, not secret keys. Keep Stripe API and webhook secrets out of this file.
STRIPE_INSTALLER_MONTHLY_URL=
STRIPE_INSTALLER_ANNUAL_URL=
STRIPE_SUPPLIER_MONTHLY_URL=
STRIPE_SUPPLIER_ANNUAL_URL=
STRIPE_BILLING_PORTAL_URL=
STRIPE_INSTALLER_MONTHLY_PAYMENT_LINK_ID=
STRIPE_INSTALLER_ANNUAL_PAYMENT_LINK_ID=
STRIPE_SUPPLIER_MONTHLY_PAYMENT_LINK_ID=
STRIPE_SUPPLIER_ANNUAL_PAYMENT_LINK_ID=

# Customer service reminder providers. Store API keys and webhook signing values
# only as protected Sites runtime secrets. Resend requires a verified sending
# domain. Twilio requires a Messaging Service, Verify Service and Australian sender.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_REPLY_TO=
RESEND_WEBHOOK_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_VERIFY_SERVICE_SID=
SERVICE_REMINDER_TWILIO_CALLBACK_URL=https://compare.ausenergyassessments.com/api/service-reminder-provider-events/twilio
