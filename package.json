{
  "name": "aea-energy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "audit:links": "node scripts/audit-links.mjs",
    "benchmark:scale": "node scripts/benchmark-scale-100k.mjs",
    "start": "vinext start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "node --experimental-strip-types --test",
    "test:coverage": "node --experimental-strip-types --experimental-test-coverage --test",
    "test:integration": "node --experimental-strip-types --test test/australian-postcodes.test.mjs test/direct-trade-matching.test.mjs test/gas-tariff-engine.test.mjs test/home-energy-plan.test.mjs test/release-integrity.test.mjs test/trade-payment-reconciliation.test.mjs",
    "db:check": "node scripts/check-migrations.mjs",
    "synthetic:validate": "node scripts/validate-synthetic-population.mjs",
    "validate": "npm run typecheck && npm run lint && npm run test:integration && npm test && npm run db:check && npm run build",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "firebase": "^12.16.0",
    "jose": "^6.2.3",
    "next": "16.2.10",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "vinext": "0.0.50"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "8.1.4",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
